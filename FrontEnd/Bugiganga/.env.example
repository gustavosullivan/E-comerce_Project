# URL do backend Spring Boot (use o IP da máquina no celular/emulador, não localhost)
EXPO_PUBLIC_API_URL=http://localhost:8765

# Integracao parcial: auth e detalhe de produto na API, demais telas no mock.
EXPO_PUBLIC_USE_REAL_AUTH=true
EXPO_PUBLIC_USE_REAL_PRODUCT_DETAILS=true
EXPO_PUBLIC_USE_REAL_PRODUCT_LIST=false

# Cloudinary — upload unsigned do app (sem API secret)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=seu_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=products-images
# Opcional: preset separado para avatares. Se omitido, usa EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET.
# EXPO_PUBLIC_CLOUDINARY_USERS_UPLOAD_PRESET=users-images
EXPO_PUBLIC_CLOUDINARY_PRODUCTS_FOLDER=produtos
EXPO_PUBLIC_CLOUDINARY_USERS_FOLDER=usuarios
